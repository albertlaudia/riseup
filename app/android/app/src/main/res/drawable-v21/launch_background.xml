<?xml version="1.0" encoding="utf-8"?>
<!-- API 21+ splash. Same as drawable/launch_background.xml but uses layer-list
     with android:src on the bitmap item, which is the modern way. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/paper" />
    <item android:gravity="center">
        <bitmap android:src="@mipmap/ic_launcher_foreground" />
    </item>
</layer-list>