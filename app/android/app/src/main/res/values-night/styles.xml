<?xml version="1.0" encoding="utf-8"?>
<!-- Dark-mode launch theme. Shown when the OS is in dark mode and we haven't
     rendered Flutter yet — keeps the same paper palette for brand consistency
     during the brief moment before Flutter paints. -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">@color/ink</item>
        <item name="android:navigationBarColor">@color/ink</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">@color/ink</item>
        <item name="android:navigationBarColor">@color/ink</item>
    </style>
</resources>