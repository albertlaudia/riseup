<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground — mountain peak + rising sun for RiseUP.
  The R-mark silhouette is in the inner safe zone (the dark mountain + sun
  shape from icon.svg, rebalanced for adaptive icon 72×72 safe area).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Mountain peak: inner safe zone (inset ~33%) -->
    <path
        android:fillColor="#1F1D1A"
        android:pathData="M36,82 L54,40 L54,82 Z" />
    <!-- Right slope of R -->
    <path
        android:fillColor="#1F1D1A"
        android:pathData="M54,82 L72,82 L54,64 Z" />
    <!-- Rising sun -->
    <path
        android:fillColor="#B9532E"
        android:pathData="M54,52 m-12,0 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0" />
    <!-- Morning star dot above sun -->
    <path
        android:fillColor="#1F1D1A"
        android:pathData="M54,30 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0" />
</vector>
