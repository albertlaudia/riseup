<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon (Android 8+). Two layers:
     - background: a flat paper-warm color
     - foreground: the R mark in accent color, inset 33% so it survives
       any circular / squircle mask the launcher applies.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/paper" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>