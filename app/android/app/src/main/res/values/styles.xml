<?xml version="1.0" encoding="utf-8"?>
<!--
  Light-mode theme for RiseUP.

  Walrus paper palette: #FAF6EF (paper), #1F1D1A (ink), #B9532E (accent).
  Source of truth: lib/theme/app_colors.dart.
  Splash uses the paper color so we don't flash white before Flutter renders.
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>
</resources>